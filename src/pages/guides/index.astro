---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('guides')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="DJI Pocket 4 & Pocket 3 Buying Guides — Accessories Tested"
  description="Tested buying guides for DJI Pocket 4 and Pocket 3 accessories: microSD cards, ND filters, cases, and more. Only gear we have actually used."
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white mb-3">Buying Guides</h1>
      <p class="text-[#9CA3AF] text-lg">Best-of lists for accessories — tested, not just listed.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={`/guides/${post.id}`}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          heroImageAlt={post.data.heroImageAlt}
          category={post.data.category}
        />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="text-[#6B7280] text-center py-20">Guides coming soon.</p>
    )}
  </div>
</BaseLayout>
