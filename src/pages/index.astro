---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = [
  ...(await getCollection('reviews')),
  ...(await getCollection('tutorials')),
  ...(await getCollection('comparisons')),
  ...(await getCollection('guides')),
];

allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = allPosts.filter((p) => p.data.featured).slice(0, 3);
const recent = allPosts.slice(0, 6);

function getPostHref(post: (typeof allPosts)[0]) {
  return `/${post.collection}/${post.id}`;
}

const categories = [
  { href: '/reviews', label: 'Reviews', icon: '🎥', desc: 'Honest gear reviews based on real-world use' },
  { href: '/tutorials', label: 'Tutorials', icon: '🎨', desc: 'Color grading, settings, and workflow guides' },
  { href: '/comparisons', label: 'Comparisons', icon: '⚖️', desc: 'Head-to-head camera and accessory comparisons' },
  { href: '/guides', label: 'Buying Guides', icon: '🛒', desc: 'Best-of lists tested and vetted by me' },
];
---

<BaseLayout
  title="The Lab for DJI Creators"
  description="Real-world reviews, color grading tutorials, and buying guides for DJI creators. No fluff — just what actually works in the field."
>
  <!-- Hero -->
  <section class="hero-section relative overflow-hidden">
    <!-- Animated background orbs -->
    <div class="hero-orb orb-orange" aria-hidden="true"></div>
    <div class="hero-orb orb-blue" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-24 text-center relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-[#FF6B35]/30 bg-[#FF6B35]/10 px-4 py-1.5 text-sm text-[#FF6B35] font-medium mb-6 animate-on-scroll">
        <span class="w-2 h-2 rounded-full bg-[#FF6B35] animate-pulse"></span>
        Real-world tested — not spec-sheet analysis
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-white mb-6 leading-tight animate-on-scroll">
        The Lab for<br /><span class="text-[#FF6B35]">DJI Creators</span>
      </h1>
      <p class="text-lg sm:text-xl text-[#9CA3AF] max-w-2xl mx-auto mb-10 leading-relaxed animate-on-scroll">
        Hands-on reviews, color grading tutorials, accessory guides, and free LUTs — for Pocket 4, Pocket 3, Osmo, Action, and drone shooters.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 animate-on-scroll">
        <a href="/reviews" class="inline-flex items-center gap-2 rounded-xl bg-[#FF6B35] px-6 py-3 font-semibold text-white transition-all hover:opacity-90 hover:scale-[1.03]">
          Read the Reviews
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="/luts" class="inline-flex items-center gap-2 rounded-xl border border-[#1F2028] bg-[#141417] px-6 py-3 font-semibold text-white transition-all hover:border-[#FF6B35]/40 hover:scale-[1.03]">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          20 Free LUTs
        </a>
      </div>
      <!-- Stat strip -->
      <div class="mt-14 flex flex-wrap justify-center gap-8 animate-on-scroll">
        {[
          { n: '20', label: 'Free LUTs' },
          { n: '4K', label: 'D-Log M tested' },
          { n: '5+', label: 'DJI cameras covered' },
          { n: '0', label: 'Spec-sheet fluff' },
        ].map(({ n, label }) => (
          <div class="text-center">
            <div class="text-2xl font-bold text-[#FF6B35]">{n}</div>
            <div class="text-xs text-[#6B7280] mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured posts -->
  {featured.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16">
      <h2 class="text-2xl font-bold text-white mb-8 animate-on-scroll">Featured from the Lab</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featured.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={getPostHref(post)}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            category={post.data.category}
            featured={true}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Categories grid -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16">
    <h2 class="text-2xl font-bold text-white mb-8 animate-on-scroll">Browse by Topic</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {categories.map(({ href, label, icon, desc }) => (
        <a href={href} class="group rounded-xl border border-[#1F2028] bg-[#141417] p-6 transition-all hover:border-[#FF6B35]/40 hover:-translate-y-1 hover:shadow-lg no-underline animate-on-scroll">
          <div class="text-3xl mb-3">{icon}</div>
          <h3 class="font-bold text-white mb-1 group-hover:text-[#FF6B35] transition-colors">{label}</h3>
          <p class="text-sm text-[#9CA3AF]">{desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest posts -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16">
    <div class="flex items-center justify-between mb-8 animate-on-scroll">
      <h2 class="text-2xl font-bold text-white">Latest from the Lab</h2>
      <a href="/reviews" class="text-sm text-[#60A5FA] hover:underline">See all</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recent.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={getPostHref(post)}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          heroImageAlt={post.data.heroImageAlt}
          category={post.data.category}
        />
      ))}
    </div>
  </section>

  <!-- Free LUT CTA -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-20">
    <div class="lut-cta-banner rounded-2xl p-8 md:p-10 flex flex-col md:flex-row gap-8 items-center justify-between animate-on-scroll">
      <div>
        <p class="text-xs text-[#FF6B35] uppercase tracking-wider font-semibold mb-2">Free Download — No Email Required</p>
        <h2 class="text-2xl font-bold text-white mb-3">20 Free LUTs for DJI D-Log M &amp; iPhone</h2>
        <p class="text-[#9CA3AF] leading-relaxed max-w-xl">
          10 DJI D-Log M looks + 10 iPhone grades. Works in DaVinci Resolve, Premiere Pro, and Final Cut Pro.
        </p>
      </div>
      <a href="/luts" class="shrink-0 inline-flex items-center gap-2 rounded-xl bg-[#FF6B35] px-6 py-3 font-semibold text-white transition-all hover:opacity-90 hover:scale-[1.03] whitespace-nowrap">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Get Free LUTs
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    background: #0A0A0B;
  }
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    animation: heroGlow 9s ease-in-out infinite;
  }
  .orb-orange {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(255,107,53,0.22), transparent 70%);
    top: -150px; left: -100px;
  }
  .orb-blue {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(96,165,250,0.18), transparent 70%);
    bottom: -100px; right: -80px;
    animation-delay: -4.5s;
  }
  @keyframes heroGlow {
    0%, 100% { opacity: 0.8; transform: scale(1) translate(0,0); }
    50%       { opacity: 1;   transform: scale(1.1) translate(20px, 15px); }
  }

  /* ── LUT CTA banner ── */
  .lut-cta-banner {
    border: 1px solid rgba(255,107,53,0.30);
    background: linear-gradient(135deg, rgba(255,107,53,0.08) 0%, rgba(255,107,53,0.04) 100%);
  }

  /* ── Light mode ── */
  :global(html.light) .hero-section { background: #F5F5F7; }
  :global(html.light) .lut-cta-banner {
    border-color: rgba(255,107,53,0.35);
    background: linear-gradient(135deg, rgba(255,107,53,0.06) 0%, rgba(255,107,53,0.02) 100%);
  }
</style>
