---
interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  heroImage: string;
  heroImageAlt: string;
  category: string;
  readingTime?: number;
  featured?: boolean;
}

const { title, description, href, pubDate, heroImage, heroImageAlt, category, readingTime, featured } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-MY', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryColor: Record<string, string> = {
  review: 'bg-[#FF6B35]/20 text-[#FF6B35]',
  tutorial: 'bg-blue-500/20 text-blue-400',
  comparison: 'bg-purple-500/20 text-purple-400',
  guide: 'bg-green-500/20 text-green-400',
};
---

<article class={`group rounded-xl border border-[#1F2028] bg-[#141417] overflow-hidden transition-all hover:border-[#FF6B35]/40 hover:shadow-lg hover:shadow-[#FF6B35]/5 ${featured ? 'ring-1 ring-[#FF6B35]/20' : ''}`}>
  <a href={href} class="block no-underline">
    <div class="aspect-[16/9] overflow-hidden bg-[#0A0A0B]">
      <img
        src={heroImage}
        alt={heroImageAlt}
        width="640"
        height="360"
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${categoryColor[category] ?? 'bg-gray-500/20 text-gray-400'}`}>
          {category.charAt(0).toUpperCase() + category.slice(1)}
        </span>
        {featured && (
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-[#FF6B35]/10 text-[#FF6B35] border border-[#FF6B35]/20">
            Featured
          </span>
        )}
      </div>
      <h2 class="text-white font-bold text-lg leading-snug mb-2 group-hover:text-[#FF6B35] transition-colors line-clamp-2">
        {title}
      </h2>
      <p class="text-[#9CA3AF] text-sm leading-relaxed line-clamp-2 mb-4">{description}</p>
      <div class="flex items-center gap-3 text-xs text-[#6B7280]">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>
    </div>
  </a>
</article>
