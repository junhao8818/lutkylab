---
interface Props {
  videoId: string;
  title: string;
}
const { videoId, title } = Astro.props;
---

<div class="not-prose my-8 aspect-video w-full overflow-hidden rounded-xl border border-[#1F2028] bg-[#0A0A0B]">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
    class="w-full h-full"
  />
</div>
