---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="not-prose my-6 rounded-xl border border-green-500/20 bg-green-500/5 p-5">
  <h3 class="flex items-center gap-2 font-bold text-green-400 mb-3 text-sm uppercase tracking-wider">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
    Pros
  </h3>
  <ul class="space-y-2">
    {items.map((item) => (
      <li class="flex items-start gap-2 text-sm text-[#D1D5DB]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        {item}
      </li>
    ))}
  </ul>
</div>
