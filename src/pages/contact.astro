---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — LUTkyLab"
  description="Get in touch with LUTkyLab. Questions about DJI cameras, color grading, collaboration inquiries — reach out."
>
  <div class="mx-auto max-w-[720px] px-4 sm:px-6 py-12">
    <h1 class="text-4xl font-bold text-white mb-4">Contact</h1>
    <p class="text-lg text-[#9CA3AF] mb-10">I read every message. Response time is usually 1–3 days.</p>

    <div class="space-y-4 not-prose">
      <div class="rounded-xl border border-[#1F2028] bg-[#141417] p-6">
        <h2 class="font-bold text-white mb-1">Email</h2>
        <p class="text-[#9CA3AF] text-sm mb-2">For questions, collaboration, or press inquiries.</p>
        <a href="mailto:hello@lutkylab.com" class="text-[#60A5FA] text-sm hover:underline">hello@lutkylab.com</a>
      </div>

      <div class="rounded-xl border border-[#1F2028] bg-[#141417] p-6">
        <h2 class="font-bold text-white mb-1">Email</h2>
        <p class="text-[#9CA3AF] text-sm mb-2">For collaboration, press, or business inquiries.</p>
        <a href="mailto:hello@lutkylab.com" class="text-[#60A5FA] text-sm hover:underline">hello@lutkylab.com</a>
      </div>
    </div>

    <div class="mt-10 rounded-xl border border-[#1F2028] bg-[#141417] p-6 not-prose">
      <h2 class="font-bold text-white mb-3">What I can help with</h2>
      <ul class="space-y-2 text-sm text-[#9CA3AF]">
        <li>✓ DJI Pocket 3 questions (settings, workflow, accessories)</li>
        <li>✓ D-Log M color grading questions</li>
        <li>✓ Content creator collaborations</li>
        <li>✓ Gear review requests (I test before recommending)</li>
      </ul>
    </div>
  </div>
</BaseLayout>
