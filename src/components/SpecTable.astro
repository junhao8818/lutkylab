---
interface Props {
  caption?: string;
  headers: string[];
  rows: string[][];
}
const { caption, headers, rows } = Astro.props;
---

<div class="not-prose my-8 overflow-x-auto rounded-xl border border-[#1F2028]">
  <table class="w-full text-sm">
    {caption && (
      <caption class="text-left text-xs text-[#6B7280] px-4 pt-3 pb-1 font-medium uppercase tracking-wider">{caption}</caption>
    )}
    <thead class="bg-[#141417]">
      <tr>
        {headers.map((h) => (
          <th class="px-4 py-3 text-left font-semibold text-[#F5F5F5] border-b border-[#1F2028]">{h}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i % 2 === 0 ? 'bg-[#0A0A0B]' : 'bg-[#141417]/50'}>
          {row.map((cell, j) => (
            <td class={`px-4 py-3 border-b border-[#1F2028] ${j === 0 ? 'font-medium text-[#F5F5F5]' : 'text-[#9CA3AF]'}`}>
              {cell}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
