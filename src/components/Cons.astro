---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="not-prose my-6 rounded-xl border border-red-500/20 bg-red-500/5 p-5">
  <h3 class="flex items-center gap-2 font-bold text-red-400 mb-3 text-sm uppercase tracking-wider">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-3.707-9.293a1 1 0 011.414-1.414L10 9.414l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-1-1a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
    Cons
  </h3>
  <ul class="space-y-2">
    {items.map((item) => (
      <li class="flex items-start gap-2 text-sm text-[#D1D5DB]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-400 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
        {item}
      </li>
    ))}
  </ul>
</div>
