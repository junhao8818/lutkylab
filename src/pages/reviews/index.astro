---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('reviews')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="DJI Camera Reviews — Pocket 4, Pocket 3, Osmo & More"
  description="Honest, hands-on reviews of DJI Pocket 4, Pocket 3, Osmo Action, and accessories. Real-world testing, not spec sheet analysis."
  breadcrumbs={[{ name: 'Reviews', url: 'https://lutkylab.com/reviews' }]}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white mb-3">Reviews</h1>
      <p class="text-[#9CA3AF] text-lg">Honest gear reviews from someone who actually shoots with it.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={`/reviews/${post.id}`}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          heroImageAlt={post.data.heroImageAlt}
          category={post.data.category}
          featured={post.data.featured}
        />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="text-[#6B7280] text-center py-20">More reviews coming soon.</p>
    )}
  </div>
</BaseLayout>
